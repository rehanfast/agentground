# AgentGround — Environment Variables Example
# Copy this file to .env and fill in your actual values.
# Never commit the actual .env to Git.

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=agentground

# Admin user — used ONLY for CREATE DATABASE and DROP DATABASE.
# If your app user already has CREATE privilege, you can leave these blank
# and the app will fall back to DB_USER / DB_PASSWORD automatically.
# DB_ADMIN_USER=root
# DB_ADMIN_PASSWORD=

# ── API Keys ──────────────────────────────────────────────────────────────────
# Add multiple keys per provider using _2, _3, … suffix.
# All keys are collected and rotated round-robin with automatic cooldown.

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google (Gemini) — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# Groq — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# xAI (Grok) — https://console.x.ai
# XAI_API_KEY=xai-...

# DeepSeek — https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-...

# ── Tavily (Web Search tool) ──────────────────────────────────────────────────
# Required for Web Search built-in tool.
# Get a free key at https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Local model via Ollama (optional) ────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Workspace ─────────────────────────────────────────────────────────────────
# Root directory for agent file sandboxes. Relative to project root.
WORKSPACE_ROOT=workspace
